<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug: разрешить HTTP к любому хосту (LAN IP ПК, эмулятор и т.д.).
  Release использует main/res/xml/network_security_config.xml.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
