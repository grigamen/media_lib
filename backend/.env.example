# Скопируйте в backend/.env и подставьте свои значения (файл .env не коммитить).
# DATABASE_URL и S3 — под ваш установленный Postgres и S3-совместимое хранилище (или облако).

DATABASE_URL=postgresql://medialib:medialib@127.0.0.1:5432/medialib

# Случайная длинная строка для продакшена; для локалки достаточно любой тестовой.
JWT_SECRET=replace-with-a-long-random-secret

# Опционально: публичный URL MinIO/S3 для presigned ссылок (мобильные клиенты).
# Пример: https://storage.example.com или http://ВАШ_IP:9000 если порт открыт.
# S3_PUBLIC_ENDPOINT_URL=

S3_BUCKET=medialib-dev
S3_REGION=us-east-1

# Пусто или не задавать — реальный AWS S3.
# Свой S3 endpoint (например MinIO на localhost): http://127.0.0.1:9000
# Android emulator: для presigned URL к хранилищу на ПК часто нужен http://10.0.2.2:9000
S3_ENDPOINT_URL=http://127.0.0.1:9000

AWS_ACCESS_KEY_ID=medialib
AWS_SECRET_ACCESS_KEY=medialib_dev_secret

# Опционально (см. app/config.py): срок presigned URL, лимиты загрузки, allowlist MIME.

# --- Email OTP (2FA) ---
# MAIL_MODE: console — код в stdout; smtp — реальная отправка; none — не слать (только запись challenge).
MAIL_MODE=console
# TWOFA_OTP_PEPPER=дополнительный-секрет-для-хеша-кода
# Для SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# MAIL_FROM=noreply@example.com
